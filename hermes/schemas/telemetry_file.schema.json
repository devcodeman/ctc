{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/schemas/telemetry_file.schema.json",
  "title": "Hermes Telemetry Analysis File",
  "description": "Accepted telemetry analysis upload format for the Hermes full telemetry page.",
  "oneOf": [
    {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/telemetryRecord"
      }
    },
    {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/telemetryRecord"
          }
        },
        "data": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/telemetryRecord"
          }
        },
        "telemetry": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/telemetryRecord"
          }
        },
        "telemetry_history": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/telemetryRecord"
          }
        }
      },
      "anyOf": [
        {
          "required": ["records"]
        },
        {
          "required": ["data"]
        },
        {
          "required": ["telemetry"]
        },
        {
          "required": ["telemetry_history"]
        }
      ],
      "additionalProperties": true
    }
  ],
  "$defs": {
    "telemetryValue": {
      "type": ["number", "string", "boolean", "null"]
    },
    "telemetryRecord": {
      "type": "object",
      "required": ["timestamp"],
      "properties": {
        "timestamp": {
          "type": ["string", "number"]
        }
      },
      "patternProperties": {
        "^(?!timestamp$).+": {
          "$ref": "#/$defs/telemetryValue"
        }
      },
      "additionalProperties": true
    }
  }
}
